# OpenStack Credentials (Required)
# IMPORTANT: These must be set either here in .env OR in the .openrc file
# If both are present, .openrc takes precedence (sourced in container)

# Admin credentials - MUST be configured
OS_PROJECT_NAME=admin
OS_USERNAME=admin
OS_PASSWORD=your-password-here  # ← REQUIRED: Cannot be empty!
OS_AUTH_URL=http://openstack:5000/v3
OS_REGION_NAME=RegionOne

# Fixed defaults (usually don't need changes)
OS_PROJECT_DOMAIN_ID=default
OS_USER_DOMAIN_ID=default
OS_IDENTITY_API_VERSION=3
OS_INTERFACE=public

# Lab Configuration
LAB_PREFIX=mylab
SSH_KEY_NAME=id_rsa