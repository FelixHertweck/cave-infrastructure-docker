# OpenStack credentials (required if not set in .openrc)
OS_PROJECT_NAME=admin
OS_USERNAME=admin
OS_PASSWORD=your-password-here  # REQUIRED
OS_AUTH_URL=http://openstack:5000/v3
OS_REGION_NAME=RegionOne

# Optional OpenStack identity settings
# Set these only if your deployment needs explicit domain or interface values.
# OS_PROJECT_DOMAIN_ID=default
# OS_USER_DOMAIN_ID=default
# OS_IDENTITY_API_VERSION=3
# OS_INTERFACE=public

# Lab configuration
LAB_PREFIX=mylab
SSH_KEY_NAME=id_rsa

# Allow insecure connections for self-signed OpenStack endpoints
# OS_INSECURE=true

# ==============================================================================
# Packer Build Configuration (for building CAVE images)
# ============================================================================

# Internal network UUID for Packer builds.
# Leave empty to auto-create or auto-discover the internal network.
OS_BUILD_NETWORK_ID=

# Floating IP network UUID for Packer builds.
# Leave empty to auto-discover external network, or set to "none" to disable floating IPs.
# OS_BUILD_FLOATING_IP_NETWORK_ID=
OS_BUILD_FLOATING_IP_NETWORK_ID=

# Flavor mapping for Packer builds.
# Maps hardcoded template flavor names to actual flavors in your OpenStack environment.
# Format: "original_flavor:mapped_flavor,another_original:another_mapped"
#
# Example:
#   OS_FLAVOR_MAP=server-small:m1.small,server-medium:m1.medium,server-large:m1.large
#
# Leave empty if no flavor remapping is required.
OS_FLAVOR_MAP=

# ==============================================================================
# Post-OpenStack Initialization (for network setup after OpenStack installation)
# ==============================================================================

# External network interface on the host machine (receives traffic from outside)
# OS_EXTERNAL_IF=enp1s0

# Bridge interface for OpenStack external network
# OS_BRIDGE_IF=br-ex

# NAT subnet for OpenStack tenant networks
# This subnet will be translated to the external interface for outbound connectivity
# OS_NAT_SUBNET=10.20.20.0/24
